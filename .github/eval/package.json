{
  "name": "skill-routing-eval",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Static analysis evaluation: embedding similarity for skill routing accuracy",
  "scripts": {
    "eval": "node score-routing.mjs",
    "eval:compare": "node score-routing.mjs --arch compare",
    "eval:main": "node score-routing.mjs --arch main",
    "eval:branch": "node score-routing.mjs --arch branch",
    "sweep": "node threshold-sweep.mjs",
    "confusion": "node confusion-matrix.mjs",
    "lint": "node lint-descriptions.mjs",
    "lint:all": "node lint-descriptions.mjs --all",
    "all": "node score-routing.mjs && node threshold-sweep.mjs && node confusion-matrix.mjs && node lint-descriptions.mjs"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "js-yaml": "^4.1.0"
  }
}
