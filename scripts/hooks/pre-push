#!/usr/bin/env bash
#
# pre-push hook — sync subtrees when pushing to remote
#
# Reads the push refspec from stdin to detect the commit range,
# then delegates to scripts/subtree-sync.sh.
#

# pre-push receives lines: <local ref> <local sha> <remote ref> <remote sha>
RANGE=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    # New branch — no prior remote SHA to diff against
    continue
  fi
  if [[ "$local_sha" != "0000000000000000000000000000000000000000" ]]; then
    RANGE="${remote_sha}..${local_sha}"
    break
  fi
done

REPO_ROOT="$(git rev-parse --show-toplevel)"
SYNC_SCRIPT="$REPO_ROOT/scripts/subtree-sync.sh"
VERIFY_SCRIPT="$REPO_ROOT/scripts/verify-instructions.js"

# ── Instruction file integrity check (RC-3) ────────────────
if [[ -x "$(command -v node)" ]] && [[ -f "$VERIFY_SCRIPT" ]]; then
  node "$VERIFY_SCRIPT" --verify
  VERIFY_EXIT=$?
  if [[ $VERIFY_EXIT -eq 1 ]]; then
    echo ""
    echo "⚠️  Instruction/skill files changed since last baseline."
    echo "   If intentional, run: node scripts/verify-instructions.js --generate"
    echo "   Then commit the updated checksums before pushing."
    # Warning only — does not block push
  fi
fi

# ── Subtree sync ───────────────────────────────────────────

if [[ ! -x "$SYNC_SCRIPT" ]]; then
  exit 0
fi

if [[ -n "$RANGE" ]]; then
  "$SYNC_SCRIPT" --range "$RANGE"
else
  "$SYNC_SCRIPT"
fi
