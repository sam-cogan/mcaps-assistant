{
  "name": "mcaps-copilot-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-powered sales operations toolkit for MCAPS — one-command setup",
  "bin": {
    "mcaps": "./bin/mcaps.js"
  },
  "scripts": {
    "setup": "node scripts/init.js",
    "check": "node scripts/init.js --check",
    "postinstall": "node scripts/init.js",
    "docs:install": "pip install -r site/requirements.txt",
    "docs:serve": "mkdocs serve",
    "docs:build": "mkdocs build",
    "docs:deploy": "mkdocs gh-deploy --force"
  },
  "engines": {
    "node": ">=18"
  }
}
