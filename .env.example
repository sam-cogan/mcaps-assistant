# Local environment configuration (created by `node scripts/init.js`)
# This file is gitignored — each user maintains their own copy.

# ── Obsidian Vault (OIL MCP Server) ─────────────────────────────
# Absolute path to your Obsidian vault directory.
# Required for the OIL (Obsidian Intelligence Layer) MCP server.
# If not set, OIL won't start; workflows fall back to stateless CRM-only mode.
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# ── Eval Framework (Phase 2 — Live Agent Loop) ──────────────────
# Required for `npm run eval:live`. Phase 1 offline evals (`npm run eval`)
# do not need any of these — they run entirely without LLM calls.
#
# Auth: Azure RBAC via DefaultAzureCredential.
# Run `az login` before running live evals. No API keys needed.

# Azure OpenAI resource endpoint — required for live evals.
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com

# Azure OpenAI API version (default: 2025-03-01-preview).
# AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Entra ID tenant that owns the Azure OpenAI resource.
# Required when the resource is on a different tenant than your default `az login`.
# AZURE_TENANT_ID=

# Deployment name for the agent under test (default: gpt-4o-mini).
# Must match a deployment in your Azure OpenAI resource.
# EVAL_MODEL=gpt-4o-mini

# Deployment name for the LLM-as-judge (default: gpt-4o-mini).
# Use a stronger model for more reliable subjective scoring.
# EVAL_JUDGE_MODEL=gpt-4o-mini

# Comma-separated deployment names for multi-model comparison.
# Only used by the "Multi-Model Comparison" test suite.
# EVAL_MODELS=gpt-4o-mini,gpt-4o

# Iterations per scenario for consistency measurement (default: 1).
# Higher values give more stable scores but cost more.
# EVAL_ITERATIONS=1

# Temperature for agent calls (default: 0). Keep at 0 for reproducible evals.
# EVAL_TEMPERATURE=0
